+"""Fragging timestamp evaluation for the Nym testbed.
+
+This script evaluates the timings after which fragment sets have been
+completed. We use it to test the hypothesis that we can notice a Fragging
+attack by an increase in time-to-fragment-set-completion.
+"""
+import sys
+from pathlib import Path
+
+DEFAULT_THRESHOLD = 2000
+
+
+def read_timestamps(threshold):
+    p = Path("./shadow.data/hosts/bob/cargo.1000.stdout")
+    if not p.exists():
+        # Can happen when installing Rust via rustup
+        p = Path("./shadow.data/hosts/bob/rustup.1000.stdout")
+
+    with open(p) as file:
+        set_map = {}
+        frag_to_sender = {}
+
+        for line in file:
+            if line.startswith("Insert"):
+                line = line.strip()
+                line = line.split("-")
+                line = line[1:]
+                frag_set = (line[0].split(":"))[1]
+                frag_idx = int(line[1].split(":")[1])
+                timestamp = int((line[2].split(":"))[1])
+                total_frags = int((line[3].split(":"))[1])
+                if not (frag_set in set_map):
+                    # (timestamp of first frag, frag ids, timestamp of latest frag, total_frags)
+                    set_map[frag_set] = (timestamp, {frag_idx}, timestamp, total_frags)
+                else:
+                    info = set_map[frag_set]
+                    set_map[frag_set] = (info[0], info[1] | {frag_idx}, max(timestamp, info[2]), total_frags)
+            elif line.startswith("Received:"):
+                if "its someone" in line:
+                    sender = "someone"
+                elif "(from eve)" in line:
+                    sender = "eve"
+                elif "(from alice)" in line:
+                    sender = "alice"
+                frag_to_sender[frag_set] = sender
+
+        for frag_set, info in set_map.items():
+            if len(info[1]) == info[3]:
+                sender = frag_to_sender[frag_set]
+                duration = info[2] - info[0]
+                print(f"Fragment set {frag_set} (sent by {sender}) is complete. Time duration between first and last fragment: {duration} milliseconds.")
+                if duration >= threshold:
+                    print("The duration is longer than our threshold of", threshold, "seconds. It is likely that packets were dropped. This fragment set was probably sent by our victim.")
+            else:
+                print("Fragment set ", frag_set, " did not complete. Amount of frags: ", info[1])
+            print("")
+
+if __name__ == "__main__":
+    print("Simulation results:")
+    threshold = DEFAULT_THRESHOLD
+    if len(sys.argv) > 1:
+        threshold = int(sys.argv[1])
+    print(f"Threshold: {threshold} milliseconds (change by giving it as an argument)\n")
+    read_timestamps(threshold)
