new file mode 100644
index 000000000..93204cda5
--- /dev/null
+++ b/common/config/src/environment.rs
@@ -0,0 +1,50 @@
+use std::fs;
+use std::env;
+use std::collections::HashMap;
+use lazy_static::lazy_static;
+use bs58;
+
+// Not intended for inserting anywhere else => no lock.
+lazy_static! {
+    static ref NODE_KEYS: (HashMap<u32, String>, HashMap<u32, String>) = {
+        let mut node_pubkeys = HashMap::new();
+        let mut node_sphinxkeys = HashMap::new();
+        // Configure which nodes you wanna use here... Their pubkeys will be loaded from ~/.nym/nym-nodes/*id*/keys, so make sure the nodes are initialized!
+        let mix_ids : Vec<u32> = vec![4,5,6,10,11];
+        for id in mix_ids {
+            let (pubkey, sphinx) = get_keys_from_file(id);
+            node_pubkeys.insert(id, pubkey);
+            node_sphinxkeys.insert(id, sphinx);
+        }
+        (node_pubkeys, node_sphinxkeys)
+    };
+    static ref PROJECT_ROOT: String = project_root::get_project_root().unwrap().to_str().unwrap()
+    .to_string();
+}
+fn get_keys_from_file(mix_id: u32) -> (String, String) {
+    let id_as_string = mix_id.to_string();
+    // Getting home directory
+    let home = dirs::home_dir().expect("Failed to retrieve home directory").to_string_lossy().to_string();
+    // Get the info from the path split with newline
+    let content = fs::read_to_string(format!("{}/.nym/nym-nodes/{}/keys", home, &id_as_string))
+        .expect("Unable to read file");
+
+    let data = content.split('\n').collect::<Vec<&str>>();
+
+
+    (data[0].to_string(), data[1].to_string())
+}
+
+pub fn get_keys_from_id(mix_id: u32) -> (String, String) {
+    let (pubkey, sphinxkey) = NODE_KEYS.clone();
+    (pubkey.get(&mix_id).unwrap().to_string(), sphinxkey.get(&mix_id).unwrap().to_string())
+}
+pub fn get_pubkey_hashmap() -> HashMap<u32, String> {
+    NODE_KEYS.0.clone()
+}
+pub fn get_sphinxkey_hashmap() -> HashMap<u32, String> {
+    NODE_KEYS.1.clone()
+}
+pub fn get_project_dir() -> String {
+    PROJECT_ROOT.clone()
+}
