diff --git a/sdk/rust/nym-sdk/src/mixnet/client_util.rs b/sdk/rust/nym-sdk/src/mixnet/client_util.rs
new file mode 100644
index 000000000..69f72cb9a
--- /dev/null
+++ b/sdk/rust/nym-sdk/src/mixnet/client_util.rs
@@ -0,0 +1,78 @@
+use std::env;
+use std::ops::Add;
+use std::path::{Path, PathBuf};
+use nym_client_core::client::base_client::storage::{GatewaysDetailsStore, MixnetClientStorage, OnDiskPersistent};
+use nym_config::environment;
+use nym_pemstore::load_key;
+use nym_sphinx::addressing::clients::ClientEncryptionKey;
+use nym_sphinx::addressing::Recipient;
+use crate::mixnet::{ClientIdentity, CredentialStorage, DisconnectedMixnetClient, MixnetClientBuilder, NodeIdentity, StoragePaths};
+
+pub struct TestClientBuilder {
+    gateway: Option<String>,
+    storage: StoragePaths
+}
+///
+/// Creating a MixnetClient for our testing purposes. Must specify the name of the client (currently),
+/// because a storage will be created.
+///
+impl TestClientBuilder {
+
+    ///
+    /// Create a new TestClientBuilder with the name of the client you want to use. This is needed
+    /// for the storage path where the keys will be stored.
+    ///
+    pub async fn new(name: &str) -> Result<Self, env::VarError> {
+        // Directory where keys are stored for the test clients
+        let dir = client_key_dir();
+        let storage = StoragePaths::new_from_dir(PathBuf::from(dir.clone().add(name))).unwrap();
+        Ok(TestClientBuilder {
+            gateway: None,
+            storage,
+        })
+    }
+
+    ///
+    /// Choose a specific gateway (using the id used in our global hashmap)
+    ///
+    pub fn with_gateway(mut self, gateway: u32) -> Self {
+        self.gateway = Some(gateway_by_id(gateway));
+        self
+    }
+
+    ///
+    /// Build a mixnet client with the desired properties
+    ///
+    pub async fn build(self) -> crate::Result<DisconnectedMixnetClient<OnDiskPersistent>> {
+        let mut client = MixnetClientBuilder::new_with_default_storage(self.storage)
+            .await
+            .unwrap();
+        // Add our custom gateway if specified
+        if let Some(gateway_id) = self.gateway {
+            client = client.request_gateway(gateway_id.clone())
+        }
+        client.build()
+    }
+}
+pub fn recipient_from_client_name(client_name: &str, gateway: u32) -> Recipient {
+    let dir = client_key_dir();
+    let ikey_path = format!("{}{}/public_identity.pem", client_key_dir(), client_name);
+    let ekey_path = format!("{}{}/public_encryption.pem", client_key_dir(), client_name);
+    // read public identity key of recipient from specified path
+    let ikey : ClientIdentity = load_key(Path::new(&ikey_path)).unwrap();
+    // read public encryption key of attacker from specified path
+    let ekey: ClientEncryptionKey = load_key(Path::new(&ekey_path)).unwrap();
+    println!("ikey {} ekey {}", ikey_path, ekey_path);
+    Recipient::new(ikey, ekey, NodeIdentity::from_base58_string(gateway_by_id(gateway))
+        .unwrap())
+}
+fn client_key_dir() -> String {
+    let mut proj_dir = environment::get_project_dir();
+    if (!proj_dir.chars().last().unwrap().eq(&'/')) {
+        proj_dir.push_str("/");
+    }
+    format!("{}client_keys/", proj_dir)
+}
+fn gateway_by_id(id: u32) -> String {
+    environment::get_pubkey_hashmap().get(&id).unwrap().clone()
+}
